<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /testfinal/

    # Rewrite empty path to public/
    RewriteRule ^$ public/ [L]

    # If the requested path is not a real directory or file,
    # rewrite it to public/index.php and let the front controller handle it.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>
